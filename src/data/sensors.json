{
  "_comment": "Sensor database. Add new groups to the 'groups' array. Add sensors to a group's 'sensors' array. All physical dimensions (w, h) are in millimetres.",
  "_schema": {
    "group": {
      "id":      "string  — unique identifier, snake_case, used in code and URLs",
      "label":   "string  — human-readable display name for the sidebar",
      "color":   "string  — hex color for UI accents (#rrggbb)",
      "sensors": "array   — list of sensor objects belonging to this group"
    },
    "sensor": {
      "id":     "string  — unique identifier, e.g. 'fxo_540'. Prefix with group id.",
      "name":   "string  — short display name shown in the sidebar and tooltip",
      "format": "string  — industry format label, e.g. '1.2\"', 'APS-C', '35mm FF'",
      "w":      "number  — sensor width  in millimetres",
      "h":      "number  — sensor height in millimetres",
      "mp":     "number  — megapixels (approximate, one decimal place)",
      "note":   "string  — technical specs: sensor die · pixel pitch · resolution · interface"
    }
  },
